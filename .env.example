# Copy this to .env and fill in your values

# Supabase — same project as Hair by Eunice is fine
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# EmailJS — create a new service at emailjs.com with veloire.info@gmail.com
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx
VITE_EMAILJS_PRIVATE_KEY=xxxxxxxxxxxxxxx

# Admin dashboard password (default: veloire2026)
VITE_ADMIN_PASSWORD=veloire2026
